---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact Us">
  <div class="max-w-3xl mx-auto mt-20 mb-32 z-10 relative animate-fade-in-down">
    <div
      class="absolute -top-32 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-indigo-500/20 blur-[100px] rounded-full pointer-events-none -z-10"
    >
    </div>

    <div class="text-center mb-16">
      <h1
        class="text-5xl md:text-6xl font-extrabold text-white mb-6 drop-shadow-md"
      >
        Let's <span class="text-indigo-400">Connect</span>
      </h1>
      <p class="text-xl text-gray-400">
        Have a question? Ping us. We're happy to help.
      </p>
    </div>

    <div
      class="glass-panel p-8 md:p-12 rounded-3xl relative overflow-hidden group"
    >
      <div
        class="absolute -inset-px bg-gradient-to-br from-indigo-500/30 to-cyan-400/10 opacity-50 pointer-events-none rounded-3xl"
      >
      </div>

      <div class="flex flex-col gap-6 relative z-10">
        <a
          href="mailto:hardikseth1975@gmail.com"
          class="flex items-center gap-6 p-6 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-cyan-400/50 transition-all duration-300 group/link"
        >
          <div
            class="p-4 rounded-xl bg-cyan-500/10 text-cyan-400 group-hover/link:bg-cyan-400 group-hover/link:text-slate-950 transition-colors"
          >
            <svg
              class="w-8 h-8"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path></svg
            >
          </div>
          <div>
            <p
              class="text-sm text-gray-400 mb-1 font-medium tracking-wide uppercase"
            >
              Email
            </p>
            <p class="text-xl font-semibold text-white">
              hardikseth1975@gmail.com
            </p>
          </div>
        </a>

        <div
          class="flex items-center gap-6 p-6 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-indigo-400/50 transition-all duration-300 group/link"
        >
          <div
            class="p-4 rounded-xl bg-indigo-500/10 text-indigo-400 group-hover/link:bg-indigo-400 group-hover/link:text-slate-950 transition-colors"
          >
            <svg
              class="w-8 h-8"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path></svg
            >
          </div>
          <div>
            <p
              class="text-sm text-gray-400 mb-1 font-medium tracking-wide uppercase"
            >
              Phone
            </p>
            <p class="text-xl font-semibold text-white">+91 9026278822</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
