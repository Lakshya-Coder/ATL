---
import Layout from '../layouts/Layout.astro';
import Carousel from '../components/Carousel.astro';
import Card from '../components/Card.astro';
import { Image } from 'astro:assets';

import imgAngled from '../assets/images/1-soan-papdi-fpga-angled.jpg';
import imgTop from '../assets/images/soan-papdi-fpga-top.jpg';
import imgBottom from '../assets/images/soan-papdi-fpga-bottom.jpg';
import imgBlink from '../assets/images/soan-papdi-alternate-led-blink.webm';
import imgLeds from '../assets/images/soan-papdi-output-leds-marked.png';
import imgSwitches from '../assets/images/soan-papdi-slide-switches-marked.png';
import statusLed from '../assets/images/soan-papdi-status-led-marked.png';
import gpioPins from '../assets/images/soan-papdi-gpio-marked.png';
import pinDiagram from '../assets/images/6-soan-papdi-pin-diagram.png';
import builtInExamples from '../assets/images/iCE-Studio-builtin-example.gif';
import gatesExample from '../assets/images/gates-example.png';
import orGate from '../assets/images/OR-Gate.jpg';
import andGate from '../assets/images/AND-Gate.jpg';
import decoder from '../assets/images/2to4-bit-decoder.jpg';
import riscv from '../assets/images/riscv-ice-studio.png';
import z80 from '../assets/images/Z80.png';
import nand2Tetris from '../assets/images/Nand2tetris.png';
import counterExample from '../assets/images/8-bit-couter-example.gif';
import hardikImg from '../assets/images/hardik1.jpg';
import piyushImg from '../assets/images/piyush.jpg';
import lskImg from '../assets/images/lsk.png';
---

<Layout title="Soan Papdi FPGA">
  <div class="max-w-5xl mx-auto mt-16 animate-fade-in-down relative z-10">
    <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-indigo-500/10 blur-[150px] rounded-full pointer-events-none -z-10"></div>
    
    <div class="text-center mb-12">
      <h1 class="text-5xl md:text-7xl font-extrabold text-white tracking-tight mb-4 drop-shadow-lg neon-text-glow">Soan Papdi <span class="text-indigo-400">FPGA</span></h1>
    </div>

    <p class="text-xl md:text-2xl leading-relaxed text-gray-400 mb-4 text-center">
      A dev board that makes learning FPGA development easy.
    </p>

    <Carousel images={[
      imgAngled,
      imgTop,
      imgBottom
    ]} />

    <div class="max-w-3xl mx-auto mt-16">
      <p class="text-xl md:text-2xl font-bold leading-relaxed text-gray-400 mb-4">
        Most FPGA boards assume you already know what you're doing.
      </p>
      <p class="text-2xl font-bold text-cyan-400 neon-text-glow mb-4">Soan Papdi doesn't.</p>

      <p class="text-xl md:text-2xl font-bold leading-relaxed text-gray-400 mb-4">
        Built for beginners, it comes with onboard LEDs, switches, and GPIO headers, so you can focus on learning FPGA instead of setting up hardware.
      </p>
    </div>

    <!-- YouTube Embed in Glass Container -->
    <div class="mt-20 glass-panel p-2 md:p-4 rounded-[2rem] mx-auto max-w-4xl shadow-[0_0_30px_rgba(99,102,241,0.15)] relative overflow-hidden group">
      <div class="absolute inset-0 bg-gradient-to-b from-indigo-500/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      <div class="aspect-video w-full rounded-3xl overflow-hidden relative z-10">
        <iframe loading="lazy" class="w-full h-full" src="https://www.youtube.com/embed/_XBXZJRrtPg" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
      </div>
    </div>


  <div class="glass-panel p-6 rounded-3xl mt-24">
  <h3 class="text-2xl font-bold text-white mb-4 flex items-center gap-3">
    <span class="w-8 h-8 rounded-full bg-cyan-500/20 flex items-center justify-center text-cyan-400">
      ⚡
    </span>
    No complex HDL needed
  </h3>

  <p class="text-gray-400 mb-4">
    Program it using the open-source iCEStudio IDE.
  </p>

  <p class="text-gray-400 mb-8">
    Just connect the blocks, and deploy your digital circuits directly to the FPGA.
  </p>
  
  <video class="w-full rounded-2xl" autoplay loop muted playsinline >
    <source src="/videos/8bitCounter.mp4" type="video/mp4" />
    Your browser does not support the video tag.
  </video>

</div>

    <div class="mt-32">
      <div class="flex items-center gap-4 mb-12">
        <h2 class="text-4xl font-display font-bold text-white uppercase tracking-wider">Specifications</h2>
        <div class="h-px bg-gradient-to-r from-indigo-500/50 to-transparent flex-1"></div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 font-mono text-sm">
        <div class="glass-panel p-6 rounded-2xl hover:border-cyan-400/50 transition-colors">
          <span class="block text-cyan-400 mb-2 text-lg font-bold">FPGA Core</span>
          <span class="text-white text-lg">Lattice iCE40UP5K</span>
        </div>
        <div class="glass-panel p-6 rounded-2xl hover:border-cyan-400/50 transition-colors">
          <span class="block text-cyan-400 mb-2 text-lg font-bold">Logic Resources</span>
          <span class="text-white text-lg">5,280 LUTs</span>
          <p class="text-gray-500 text-xs mt-1">(capable of hosting RISC-V)</p>
        </div>
        <div class="glass-panel p-6 rounded-2xl hover:border-cyan-400/50 transition-colors">
          <span class="block text-cyan-400 mb-2 text-lg font-bold">Embedded Memory</span>
          <span class="text-white text-lg">120 Kb BRAM / 1 Mb SPRAM</span>
        </div>
        <div class="glass-panel p-6 rounded-2xl hover:border-cyan-400/50 transition-colors">
          <span class="block text-cyan-400 mb-2 text-lg font-bold">SPRAM</span>
          <span class="text-white text-lg">128 Mbit SPI Flash</span>
        </div>
        <div class="glass-panel p-6 rounded-2xl hover:border-cyan-400/50 transition-colors">
          <span class="block text-cyan-400 mb-2 text-lg font-bold">Internal Oscillators</span>
          <span class="text-white text-lg">10 kHz and 48 MHz</span>
        </div>
        <div class="glass-panel p-6 rounded-2xl hover:border-cyan-400/50 transition-colors">
          <span class="block text-cyan-400 mb-2 text-lg font-bold">Hard IP</span>
          <span class="text-white text-lg">2 × SPI, 2 × I²C</span>
        </div>
        <div class="glass-panel p-6 rounded-2xl hover:border-cyan-400/50 transition-colors">
          <span class="block text-cyan-400 mb-2 text-lg font-bold">DSP Resources</span>
          <span class="text-white text-lg">8 × DSP multiplier blocks</span>
        </div>
        <div class="glass-panel p-6 rounded-2xl hover:border-cyan-400/50 transition-colors">
          <span class="block text-cyan-400 mb-2 text-lg font-bold">Onboard Storage</span>
          <span class="text-white text-lg">128 Mbit onboard SPI Flash</span>
        </div>

        <div class="glass-panel p-6 rounded-2xl hover:border-cyan-400/50 transition-colors">
          <span class="block text-cyan-400 mb-2 text-lg font-bold">Interface</span>
          <span class="text-white text-lg">USB-C (DFU Bootloader)</span>
        </div>

        <div class="glass-panel p-6 rounded-2xl hover:border-cyan-400/50 transition-colors">
          <span class="block text-cyan-400 mb-2 text-lg font-bold">Power</span>
          <span class="text-white text-lg">5 Volts</span>
        </div>

        <div class="glass-panel p-6 rounded-2xl hover:border-cyan-400/50 transition-colors">
          <span class="block text-cyan-400 mb-2 text-lg font-bold">Dimensions</span>
          <span class="text-white text-lg">67.5mm x 45.5mm</span>
        </div>

        <div class="glass-panel p-6 rounded-2xl hover:border-cyan-400/50 transition-colors">
          <span class="block text-cyan-400 mb-2 text-lg font-bold">Platform</span>
          <span class="text-white text-lg">Windows, macOS & Linux</span>
        </div>

      </div>
    </div>

    <div class="glass-panel p-6 rounded-2xl hover:border-cyan-400/50 transition-colors mt-6">
      <span class="block text-cyan-400 mb-4 text-lg font-bold">
        User Interface
      </span>

      <ul class="space-y-2 text-white text-lg">
        <li>• 8 × Yellow 3.0 mm through-hole LEDs (D7–D0)</li>
        <li>• 4 × White 0603 SMD status LEDs (S3–S0)</li>
        <li>• 8 × DIP switches with orange indicator LEDs</li>
        <li>• 2 × Push buttons (Program & Reset)</li>
        <li>• 10 × GPIO pins for external sensors & peripherals</li>
      </ul>
    </div>

    <div class="glass-panel p-8 rounded-2xl hover:border-cyan-400/50 transition-colors mt-6">
      <h3 class="text-cyan-400 text-lg font-bold mb-4">
        Supported Toolchains
      </h3>

      <p class="text-white text-lg">
        iCE Studio, APIO, Yosys, nextpnr, IceStorm, Icarus Verilog, Amaranth HDL.
      </p>
    </div>

    <!-- UI Components Section -->
    <div class="mt-32 relative">
      <div class="absolute right-0 top-1/2 w-[400px] h-[400px] bg-cyan-500/10 blur-[150px] rounded-full pointer-events-none -z-10"></div>
      <h2 class="text-4xl font-display font-bold text-white mb-12 text-center">Designed for Learning</h2>
      
      <div class="space-y-6">
        <!-- Output Leds -->
        <div class="glass-panel rounded-3xl p-6">
          <div class="flex flex-col md:flex-row items-center gap-12">
            
            <div class="w-full md:w-3/5 lightbox-trigger">
              <Image
                src={imgLeds}
                alt="Output LEDs"
                class="w-full rounded-2xl"
              />
            </div>

            <div class="w-full md:w-1/2">
              <h3 class="text-3xl font-bold text-white mb-4">
                Output LEDs
              </h3>

              <p class="text-gray-400 text-lg leading-relaxed">
                8-bit data is very common, things like counters or state machines, you can directly see the output on these LEDs.
              </p>
            </div>
          </div>
        </div>

        <!-- Status Leds -->
        <div class="glass-panel rounded-3xl p-6">
          <div class="flex flex-col md:flex-row-reverse items-center gap-12">

            <div class="w-full md:w-3/5 lightbox-trigger">
              <Image
                src={statusLed}
                alt="Input Switches"
                class="w-full rounded-2xl"
              />
            </div>

            <div class="w-full md:w-2/5">
              <h3 class="text-3xl font-bold text-white mb-4">
                Status LEDs
              </h3>

              <p class="text-gray-400 text-lg leading-relaxed">
                Signals like carry flags, overflow indicators can be shown here.
              </p>
            </div>

          </div>
        </div>

        <!-- Input Switches -->
        <div class="glass-panel rounded-3xl p-6">
          <div class="flex flex-col md:flex-row items-center gap-12">
            
            <div class="w-full md:w-3/5 lightbox-trigger">
              <Image
                src={imgSwitches}
                alt="Output LEDs"
                class="w-full rounded-2xl"
              />
            </div>

            <div class="w-full md:w-1/2">
              <h3 class="text-3xl font-bold text-white mb-4">
                Input Switches
              </h3>

              <p class="text-gray-400 text-lg leading-relaxed">
                Using these switches, you can input two 4-bit numbers into your circuit. Now you can add, subtract & instantly see the result on the LEDs.
              </p>
            </div>
          </div>
        </div>

        <!-- GPIO Pins -->
        <div class="glass-panel rounded-3xl p-6">
          <div class="flex flex-col md:flex-row-reverse items-center gap-12">

            <div class="w-full md:w-3/5 lightbox-trigger">
              <Image
                src={gpioPins}
                alt="Input Switches"
                class="w-full rounded-2xl"
              />
            </div>

            <div class="w-full md:w-2/5">
              <h3 class="text-3xl font-bold text-white mb-4">
                GPIO Headers
              </h3>

              <p class="text-gray-400 text-lg leading-relaxed">
                These headers let you connect external components like sensors, displays, motors, or your own custom hardware to extend the capabilities of Soan Papdi.
              </p>
            </div>

          </div>
        </div>

        <!-- Pin Diagram -->
        <div class="glass-panel rounded-3xl p-6">
          <h3 class="text-3xl font-bold text-white mb-6">
            Pin Diagram
          </h3>

          <div class="lightbox-trigger">
            <Image
              src={pinDiagram}
              alt="Pin Diagram"
              class="w-full rounded-2xl"
            />
          </div>
        </div>


      </div>
    </div>

    <div class="mt-16 mb-10">
      <div class="flex items-center gap-4 mb-12">
        <h2 class="text-4xl font-display font-bold text-white uppercase tracking-wider">Learning Resources</h2>
        <div class="h-px bg-gradient-to-r from-cyan-500/50 to-transparent flex-1"></div>
      </div>

      <p class="text-xl text-gray-400 mb-12">To make things easier, Piyush has created a Digital Electronics 101 course, where everything is explained step by step.</p>

      <!-- YouTube Playlist Embed -->
      <div class="mt-6 glass-panel p-2 md:p-4 rounded-[2rem] mx-auto max-w-4xl shadow-[0_0_30px_rgba(99,102,241,0.15)] relative overflow-hidden group">
        <div class="absolute inset-0 bg-gradient-to-b from-indigo-500/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="aspect-video w-full rounded-3xl overflow-hidden relative z-10">
          <iframe
            loading="lazy"
            class="w-full h-full"
            src="https://www.youtube.com/embed/videoseries?list=PLTbERlX_4R03Ru_9ee6_U0GgTcg858amo"
            title="Soan Papdi Tutorials Playlist"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen>
          </iframe>
        </div>
      </div>

      <p class="mt-10 text-xl text-gray-400 mb-12">You can explore built-in examples and learn by doing.</p>

      <div class="glass-panel rounded-3xl p-5">
        <div class="lightbox-trigger">
          <video class="w-full rounded-2xl" autoplay loop muted playsinline >
            <source src="/videos/icestudioExamples.mp4" type="video/mp4" />
            Your browser does not support the video tag.
          </video>
        </div>
      </div>

      <p class="mt-10 text-xl text-gray-400 mb-12">Start simple — build basic gates like AND, OR, or a decoder.</p>
      
      <Carousel images={[
        andGate,
        orGate,
        decoder
      ]} />

      <p class="mt-10 text-xl text-gray-400 mb-12">
        Once you’re comfortable with the basics, move on to these advanced projects:
      </p>

      
      <ol class="list-decimal pl-6 space-y-2 text-xl text-gray-400">
        <li>
          <strong><a href="https://github.com/Obijuan/RISC-V-FPGA" target="_blank" rel="noopener noreferrer" class="text-cyan-400 hover:text-cyan-300">
            RISC-V CPU
          </a></strong>
          — Build and run a RISC-V processor on your FPGA.
        </li>

        <li>
          <strong><a href="https://github.com/Obijuan/Z80-FPGA" target="_blank" rel="noopener noreferrer" class="text-cyan-400 hover:text-cyan-300">
            Z80 CPU
          </a></strong>
          — Recreate the classic Z80 microprocessor using open-source FPGA tools.
        </li>

        <li>
          <strong><a href="https://github.com/Obijuan/nand2tetris-icestudio" target="_blank" rel="noopener noreferrer" class="text-cyan-400 hover:text-cyan-300">
            Hack CPU
          </a></strong>
          — Implement the Nand2Tetris Hack CPU, built gate by gate.
        </li>
      </ol>

      <Carousel images={[
        riscv,
        z80,
        nand2Tetris
      ]} />
    
      
      

    </div>

    <div class="mt-32 mb-10">
      <div class="flex items-center gap-4 mb-12">
        <h2 class="text-4xl font-display font-bold text-white uppercase tracking-wider">The Team</h2>
        <div class="h-px bg-gradient-to-r from-cyan-500/50 to-transparent flex-1"></div>
      </div>
      <p class="text-xl text-gray-400 mb-12">Proposal of Soan Papdi was made by Piyush, the idea was brought to life by Hardik & Lakshya.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Team Member 1 -->
        <div class="glass-panel p-8 rounded-3xl group">
          <div class="flex flex-col xl:flex-row gap-6 items-start">
            <Image src={hardikImg} alt="Hardik Seth" class="w-[120px] h-[120px] object-cover rounded-2xl border border-white/10 shrink-0" />
            <div>
              <h3 class="text-2xl font-bold text-white mb-1">Hardik Seth</h3>
              <p class="text-indigo-400 text-sm font-medium mb-1 uppercase tracking-wide">Embedded Engineer</p>
              <p class="text-xs text-gray-500 mb-3 bg-white/5 inline-block px-2 py-0.5 rounded-full border border-white/10">STEMpedia</p>
              <div class="flex gap-3 text-sm mb-4">
                <a href="https://www.linkedin.com/in/hardik-seth-8687b7201/" class="text-gray-400 hover:text-cyan-400 transition-colors">LinkedIn</a>
                <a href="https://x.com/DIY_With_Hardik" class="text-gray-400 hover:text-cyan-400 transition-colors">X</a>
                <a href="https://www.youtube.com/@DIYwithHardik" class="text-gray-400 hover:text-cyan-400 transition-colors">YouTube</a>
              </div>
              <p class="text-gray-400 text-sm leading-relaxed">
                Engineer by day, Maker by night - playing with electronics since the age of 9. Currently working as embedded engineer who designs PCBs, writes firmware, and enjoys turning ideas into complete, working hardware products.
              </p>
            </div>
          </div>
        </div>

        <!-- Team Member 2 -->
        <div class="glass-panel p-8 rounded-3xl group">
          <div class="flex flex-col xl:flex-row gap-6 items-start">
            <Image src={piyushImg} alt="Piyush Itankar" class="w-[120px] h-[120px] object-cover rounded-2xl border border-white/10 shrink-0" />
            <div>
              <h3 class="text-2xl font-bold text-white mb-1">Piyush Itankar</h3>
              <p class="text-cyan-400 text-sm font-medium mb-1 uppercase tracking-wide">Senior Embedded SW Engineer</p>
              <p class="text-xs text-gray-500 mb-3 bg-white/5 inline-block px-2 py-0.5 rounded-full border border-white/10">Google | Ex-Intel</p>
              <div class="flex gap-3 text-sm mb-4">
                <a href="https://www.linkedin.com/in/streetdogg/" class="text-gray-400 hover:text-indigo-400 transition-colors">LinkedIn</a>
                <a href="https://x.com/_streetdogg" class="text-gray-400 hover:text-indigo-400 transition-colors">X</a>
                <a href="https://www.youtube.com/@pyjamacafe" class="text-gray-400 hover:text-indigo-400 transition-colors">YouTube</a>
              </div>
              <p class="text-gray-400 text-sm leading-relaxed">
                Electrical Engineer holding a Master’s degree in Embedded Systems, with a proven track record at industry giants. Currently thriving as an Embedded Software Engineer at Google.
              </p>
            </div>
          </div>
        </div>

        <!-- Team Member 3 -->
        <div class="glass-panel p-8 rounded-3xl group md:col-span-2 max-w-3xl mx-auto">
          <div class="flex flex-col xl:flex-row gap-6 items-start">
            <Image src={lskImg} alt="Lakshya Seth" class="w-[120px] h-[120px] object-cover rounded-2xl border border-white/10 shrink-0" />
            <div>
              <h3 class="text-2xl font-bold text-white mb-1">Lakshya Seth</h3>
              <p class="text-indigo-400 text-sm font-medium mb-1 uppercase tracking-wide">Digital Craftsman</p>
              <p class="text-xs text-gray-500 mb-3 bg-white/5 inline-block px-2 py-0.5 rounded-full border border-white/10">Class 12th student</p>
              <div class="flex gap-3 text-sm mb-4">
                <a href="https://www.linkedin.com/in/lakshyaseth7089/" class="text-gray-400 hover:text-cyan-400 transition-colors">LinkedIn</a>
                <a href="https://www.youtube.com/@lakshyaseth7089" class="text-gray-400 hover:text-cyan-400 transition-colors">YouTube</a>
              </div>
              <p class="text-gray-400 text-sm leading-relaxed">
                Love to build things, breaking and tearing things apart, to really learn how it's working. I like to play with Arch Linux and electronics.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-32 mb-20">
      <div class="glass-panel p-12 rounded-[3rem] text-center max-w-3xl mx-auto relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-t from-indigo-500/20 to-transparent pointer-events-none"></div>
        <h2 class="text-3xl font-bold text-white mb-6">Acquire Soan Papdi</h2>
        <p class="text-gray-400 mb-8">Join the hardware revolution. Pre-order your development kit on CrowdSupply today.</p>
        <div class="flex justify-center">
           <Card title="View on CrowdSupply" link="https://www.crowdsupply.com/ashoktinkeringlabs/soan-papdi" icon="true" />
        </div>
      </div>
    </div>

  </div>
</Layout>
