---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Lightbox from '../components/Lightbox.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Ashok Tinkering Labs - Making complex tech simple through hands-on learning." />
    <title>{title} | Ashok Tinkering Labs</title>
  </head>
  <body class="min-h-screen flex flex-col font-sans overflow-x-hidden">
    <Navbar />
    
    <main class="flex-grow w-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <slot />
    </main>
    
    <Footer />
    <Lightbox />
  </body>
</html>
